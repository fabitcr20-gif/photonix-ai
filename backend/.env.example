APP_ENV=development

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=changeme
SUPABASE_SERVICE_ROLE_KEY=changeme
SUPABASE_JWT_SECRET=changeme

# --- Fundador / Administrador (acceso gratuito e ilimitado de por vida) ---
FOUNDER_ADMIN_EMAIL=fabitcr20@gmail.com

# --- SINPE Móvil ---
SINPE_PHONE_NUMBER=8888-8888
SINPE_OWNER_NAME=Photonix AI

# --- Correo (recordatorios automáticos de pago) ---
# Si se dejan vacíos, los correos solo se registran en logs (modo desarrollo).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Photonix AI <no-reply@photonix.ai>
REMINDER_DAYS_BEFORE_EXPIRY=3
ENABLE_REMINDER_SCHEDULER=false

# --- Integraciones de exportación (opcionales) ---
# Sin esto, los botones de "Google Drive" / "Instagram" muestran un aviso de
# que falta configuración, en vez de fallar en silencio.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con el "Authorized redirect URI" configurado en
# Google Cloud Console. Ajusta el puerto/dominio según dónde corra tu backend.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/export/google-drive/callback
INSTAGRAM_ACCESS_TOKEN=

# --- URL del frontend (a dónde redirigir tras conectar Google Drive) ---
FRONTEND_URL=http://localhost:3000

# --- Secreto para firmar tokens internos (ej. el "state" del OAuth) ---
# Genera uno propio y aleatorio, ej: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=changeme-genera-un-secreto-aleatorio-largo

# --- Storage ---
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=100
# Con STORAGE_PROVIDER='local', debe apuntar al puerto real donde corre este
# backend (se usa para armar URLs http de fotos/logos servidas por /media).
BACKEND_PUBLIC_URL=http://localhost:8000

# --- CORS ---
# En producción, agrega aquí el dominio real del frontend (Vercel y/o tu
# dominio propio), ej: ["https://photonixai.cr","https://www.photonixai.cr","https://tu-proyecto.vercel.app"]
FRONTEND_ORIGINS=["http://localhost:3000"]
